# Example environment config for claude-code-proxy
# Values here are safe defaults; copy to .env and edit as needed.
port=42069
host=0.0.0.0
backend=openai
auth_mode=api_key
openai_api_key=sk-your-openai-key
openai_base_url=https://api.openai.com/v1/chat/completions
token_broker_url=
log_level=INFO
log_format=text
filter_sampling_params=false
max_body_bytes=10485760
cors_origin=*
rate_limit_enabled=true
rate_limit_max_requests=60
rate_limit_window_ms=60000
